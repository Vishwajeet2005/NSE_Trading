# .env.example
# ==============================================================================
# SECRETS CONFIGURATION TEMPLATE
# Copy this file to .env and replace the placeholders with your actual secrets.
# NEVER commit the actual .env file to version control.
# ==============================================================================

# ── API Protection ────────────────────────────────────────────────────────────
# Used by the frontend to authenticate with protected FastAPI routes (e.g. /approve)
APP_ADMIN_KEY=replace-with-a-secure-random-string

# ── Zerodha Kite Connect ──────────────────────────────────────────────────────
# Required for real-money trade execution. Leave blank if purely paper trading.
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_API_SECRET=your_zerodha_api_secret_here
ZERODHA_ACCESS_TOKEN=your_zerodha_access_token_here

# ── Telegram Notifications ────────────────────────────────────────────────────
# Required for trade execution alerts. 
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Groq AI Engine ────────────────────────────────────────────────────────────
# Required for the NLP Sentiment Analysis and Random Forest prediction endpoints.
GROQ_API_KEY=gsk_your_groq_api_key_here
